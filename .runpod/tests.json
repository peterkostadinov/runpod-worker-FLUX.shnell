{
  "tests": [
    {
      "name": "basic_image_generation",
      "input": {
        "prompt": "A beautiful sunset over mountains, highly detailed",
        "height": 1024,
        "width": 1024,
        "num_inference_steps": 4,
        "seed": 42,
        "num_images": 1
      },
      "timeout": 60000
    },
    {
      "name": "custom_resolution",
      "input": {
        "prompt": "A cat sitting on a windowsill, soft lighting",
        "height": 768,
        "width": 1344,
        "num_inference_steps": 4,
        "seed": 123,
        "num_images": 1
      },
      "timeout": 60000
    },
    {
      "name": "multiple_images",
      "input": {
        "prompt": "A steampunk dragon soaring through clouds, golden hour",
        "height": 1024,
        "width": 1024,
        "num_inference_steps": 4,
        "seed": 7,
        "num_images": 2
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA A40",
    "gpuCount": 1,
    "env": [
      {
        "key": "HF_MODEL",
        "value": "PrunaAI/FLUX.1-schnell-smashed-no-compile"
      }
    ],
    "allowedCudaVersions": [
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2",
      "12.1"
    ]
  }
}
