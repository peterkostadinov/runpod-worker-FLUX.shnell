{
  "title": "FLUX.1-schnell",
  "description": "Generate images with FLUX.1-schnell via Hugging Face Diffusers.",
  "type": "serverless",
  "category": "image",
  "iconUrl": "",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 80,
    "gpuIds": "AMPERE_48,ADA_48_PRO,AMPERE_80,ADA_80_PRO",
    "gpuCount": 1,
    "allowedCudaVersions": [
      "12.7", "12.6", "12.5", "12.4", "12.3", "12.2", "12.1"
    ],
    "presets": [
      {
        "name": "FLUX.1-schnell (default)",
        "defaults": {
          "HF_MODEL": "black-forest-labs/FLUX.1-schnell"
        }
      }
    ],
    "env": [
      {
        "key": "HF_MODEL",
        "input": {
          "type": "huggingface",
          "name": "Hugging Face Model",
          "description": "FLUX model ID as listed on Hugging Face Hub",
          "default": "black-forest-labs/FLUX.1-schnell"
        }
      }
    ]
  }
}