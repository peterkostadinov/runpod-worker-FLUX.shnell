# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Hugging Face
# ---------------------------------------------------------------------------

# Required for gated models (e.g. black-forest-labs/FLUX.1-schnell).
# Create a token at https://huggingface.co/settings/tokens (read access is enough).
HF_TOKEN=your_hf_token_here

# Optional: override the default model (default: black-forest-labs/FLUX.1-schnell)
# HF_MODEL=black-forest-labs/FLUX.1-schnell

# ---------------------------------------------------------------------------
# Local server
# ---------------------------------------------------------------------------

# API key required by the local server's Bearer auth.
# If not set, a random key is auto-generated and printed at startup.
API_KEY=your_api_key_here

# Base URL used by test_local.py (default: http://localhost:8000)
LOCAL_SERVER_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# RunPod (only needed for test_endpoint.py against the cloud endpoint)
# ---------------------------------------------------------------------------

RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=xxhqzchmu891f1

# ---------------------------------------------------------------------------
# S3-compatible bucket (optional — local server returns base64 if unset)
# ---------------------------------------------------------------------------

# BUCKET_ENDPOINT_URL=https://s3.amazonaws.com
# BUCKET_ACCESS_KEY_ID=
# BUCKET_SECRET_ACCESS_KEY=
#
